#!/usr/bin/env bash
# rp-governance-install - install governance kit into Retailpulses repos
set -euo pipefail

KIT_REPO="retailpulses/rp-governance-kit"
KIT_REF="main"
DRY_RUN=false
FORCE=false
REPOS_FILE=""
REPOS=()
INSTALLED=()
UPTODATE=()
FAILED=()
SKIPPED=()
PR_URLS=()
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
KIT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

usage() {
  cat <<-USAGE
Usage:
  bin/rp-governance-install <owner/repo> [options]
  bin/rp-governance-install --repos repos.txt [options]

Options:
  --repos <file>  Batch mode: one owner/repo per line; blank lines and # comments ignored.
  --ref <ref>     Governance kit ref used by the workflow wrapper. Default: main.
  --dry-run       Print planned changes without pushing branches or opening PRs.
  --force         Overwrite repo-specific docs stubs.
  --help          Show this help.
USAGE
}

die() {
  echo "Error: $*" >&2
  exit 1
}

preflight() {
  if ! command -v gh &>/dev/null; then
    die "gh CLI not installed. Install from https://cli.github.com/"
  fi
  if ! gh auth status &>/dev/null; then
    die "gh CLI not authenticated. Run 'gh auth login' first."
  fi
  for script in rp-issue-create rp-issue-audit rp-issue-work rp-issue-closeout rp-deploy-closeout rp-repo-housekeeping; do
    [[ -f "$KIT_DIR/templates/bin/$script" ]] || die "Missing kit template: templates/bin/$script"
  done
  for doc in 00_CURRENT_STATE.md 05_DECISION_LOG.md 16_DATABASE_GOVERNANCE.md; do
    [[ -f "$KIT_DIR/templates/docs/$doc" ]] || die "Missing kit template: templates/docs/$doc"
  done
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)
        usage
        exit 0
        ;;
      --repos)
        [[ $# -ge 2 ]] || die "--repos requires a file"
        REPOS_FILE="$2"
        shift 2
        ;;
      --ref)
        [[ $# -ge 2 ]] || die "--ref requires a value"
        KIT_REF="$2"
        shift 2
        ;;
      --dry-run)
        DRY_RUN=true
        shift
        ;;
      --force)
        FORCE=true
        shift
        ;;
      -*)
        die "Unknown option: $1"
        ;;
      *)
        REPOS+=("$1")
        shift
        ;;
    esac
  done

  if [[ -n "$REPOS_FILE" ]]; then
    [[ -f "$REPOS_FILE" ]] || die "Repos file not found: $REPOS_FILE"
    while IFS= read -r repo || [[ -n "$repo" ]]; do
      repo="${repo%%#*}"
      repo="$(echo "$repo" | xargs)"
      [[ -n "$repo" ]] && REPOS+=("$repo")
    done < "$REPOS_FILE"
  fi

  [[ ${#REPOS[@]} -gt 0 ]] || {
    usage
    exit 1
  }
}

repo_json_field() {
  local repo="$1"
  local field="$2"
  gh repo view "$repo" --json "$field" --jq ".$field" 2>/dev/null
}

default_branch() {
  local repo="$1"
  gh repo view "$repo" --json defaultBranchRef --jq '.defaultBranchRef.name' 2>/dev/null || echo "main"
}

is_archived() {
  local repo="$1"
  [[ "$(repo_json_field "$repo" isArchived)" == "true" ]]
}

find_existing_pr() {
  local repo="$1"
  local branch="$2"
  gh pr list --repo "$repo" --head "$branch" --state open --json url --jq '.[0].url // ""' 2>/dev/null
}

is_up_to_date() {
  local dir="$1"
  local expected_files=(
    ".github/workflows/governance-checks.yml"
    ".github/workflows/database-governance.yml"
    ".github/pull_request_template.md"
    "bin/rp-issue-create"
    "bin/rp-issue-audit"
    "bin/rp-issue-work"
    "bin/rp-issue-closeout"
    "bin/rp-deploy-closeout"
    "bin/rp-repo-housekeeping"
    "docs/16_DATABASE_GOVERNANCE.md"
  )
  local f
  for f in "${expected_files[@]}"; do
    [[ -f "$dir/$f" ]] || return 1
  done
  grep -q "retailpulses/rp-governance-kit" "$dir/.github/workflows/governance-checks.yml" 2>/dev/null || return 1
  grep -q "rp-issue-audit" "$dir/bin/rp-issue-work" 2>/dev/null || return 1
  grep -q "16_DATABASE_GOVERNANCE" "$dir/docs/16_DATABASE_GOVERNANCE.md" 2>/dev/null || return 1
  return 0
}

copy_files() {
  mkdir -p bin .github .github/workflows docs

  local script
  for script in rp-issue-create rp-issue-audit rp-issue-work rp-issue-closeout rp-deploy-closeout rp-repo-housekeeping; do
    cp "$KIT_DIR/templates/bin/$script" "bin/$script"
    chmod +x "bin/$script"
  done

  cp "$KIT_DIR/templates/github/pull_request_template.md" ".github/pull_request_template.md"
  sed "s/__REF__/$KIT_REF/g" "$KIT_DIR/templates/github/workflows/governance-checks-wrapper.yml" > ".github/workflows/governance-checks.yml"

  local wrapper_src="$KIT_DIR/templates/github/workflows/post-deploy-governance-wrapper.yml"
  if [[ -f "$wrapper_src" ]]; then
    sed "s/__REF__/$KIT_REF/g" "$wrapper_src" > ".github/workflows/post-deploy-governance.yml" 2>/dev/null || true
  fi

  sed "s/__REF__/$KIT_REF/g" "$KIT_DIR/templates/github/workflows/database-governance-wrapper.yml" > ".github/workflows/database-governance.yml"

  local installed_at
  installed_at=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

  local doc
  for doc in 00_CURRENT_STATE.md 05_DECISION_LOG.md 10_ENGINEERING_PRINCIPLES.md 11_FRONTEND_STANDARDS.md 12_DATA_ACCESS_AND_SECRETS.md 13_PLATFORM_DEPENDENCY_POLICY.md 14_ISSUE_GOVERNANCE.md 15_DEPLOYMENT_AND_HOUSEKEEPING.md; do
    if [[ ! -f "docs/$doc" || "$FORCE" == true ]]; then
      cp "$KIT_DIR/templates/docs/$doc" "docs/$doc"
    fi
  done

  # 16_DATABASE_GOVERNANCE.md is always updated with the new ref (it's a managed reference, not repo-owned).
  # Repo-specific declarations live in docs/16_DATABASE_GOVERNANCE.local.md which is never overwritten.
  sed -e "s/__REF__/$KIT_REF/g" -e "s/__INSTALLED_AT__/$installed_at/g" \
    "$KIT_DIR/templates/docs/16_DATABASE_GOVERNANCE.md" > "docs/16_DATABASE_GOVERNANCE.md"

  # Record installed governance ref for upgrade detection
  echo "$KIT_REF" > ".github/governance-ref.txt"

  touch .gitignore
  if ! grep -q '^\.tmp/' .gitignore 2>/dev/null; then
    {
      echo ""
      echo "# Temp files"
      echo ".tmp/"
    } >> .gitignore
  fi
}

has_changes() {
  ! git diff --quiet || ! git diff --cached --quiet || [[ -n "$(git ls-files --others --exclude-standard)" ]]
}

install_one() {
  local repo="$1"
  local branch="chore/install-governance-kit"
  local tmpdir base existing_pr pr_url
  local start_dir="$KIT_DIR"

  echo ""
  echo "========================================"
  echo "Processing: $repo"
  echo "========================================"

  if is_archived "$repo"; then
    echo "Skipping archived repo: $repo"
    SKIPPED+=("$repo (archived)")
    return
  fi

  base=$(default_branch "$repo")
  existing_pr=$(find_existing_pr "$repo" "$branch")

  cd /tmp
  tmpdir=$(mktemp -d "/tmp/rp-governance-XXXXXX")

  echo "Cloning $repo ..."
  if ! gh repo clone "$repo" "$tmpdir" -- --quiet; then
    echo "Failed to clone $repo"
    FAILED+=("$repo (clone failed)")
    cd "$start_dir"
    rm -rf "$tmpdir"
    return
  fi

  cd "$tmpdir"
  git fetch origin "$branch" --quiet 2>/dev/null || true
  git switch -c "$branch" "origin/$branch" 2>/dev/null || git switch -c "$branch" 2>/dev/null || git switch "$branch"

  if is_up_to_date "$tmpdir"; then
    echo "Already up to date: $repo"
    UPTODATE+=("$repo")
    cd "$start_dir"
    rm -rf "$tmpdir"
    return
  fi

  copy_files

  if ! has_changes; then
    echo "No changes to commit: $repo"
    UPTODATE+=("$repo")
    cd "$start_dir"
    rm -rf "$tmpdir"
    return
  fi

  echo "Changes:"
  git status --short

  if [[ "$DRY_RUN" == true ]]; then
    echo "[DRY-RUN] Would commit, push, and open/update PR for $repo"
    INSTALLED+=("$repo (dry-run)")
    cd "$start_dir"
    rm -rf "$tmpdir"
    return
  fi

  git add -A
  git commit -m "chore: install governance kit" -m "Install centralized governance kit $KIT_REPO@$KIT_REF." >/dev/null
  git push -u origin "$branch" --quiet

  if [[ -n "$existing_pr" ]]; then
    echo "Updated existing PR: $existing_pr"
    PR_URLS+=("$repo -> $existing_pr")
    INSTALLED+=("$repo (updated PR)")
  else
    pr_url=$(gh pr create \
      --repo "$repo" \
      --head "$branch" \
      --base "$base" \
      --title "chore: install governance kit" \
      --body "## Linked Issue

Related to retailpulses/rp-governance-kit#2

## What Changed

Install the centralized Retailpulses governance kit.

## Why

Keeps this repository aligned with current Issue-first governance and prevents raw low-structure Issue creation from becoming the normal agent workflow.

## User Impact

- [x] No user-facing change
- [ ] Changes user workflow - describe:

## System Impact

- [ ] No system impact
- [ ] Database migration
- [ ] Schema/types changed
- [ ] Routes/pages changed
- [x] Agent configuration changed
- [x] Other: repository governance scripts, PR workflow wrapper, and database governance reference

## Data Model Impact

- [x] No data model changes
- [ ] Existing tables reused
- [ ] New tables/columns added - justify:

## Documentation Impact

- [ ] No docs changes needed
- [x] docs/00_CURRENT_STATE.md updated
- [x] docs/05_DECISION_LOG.md updated
- [x] docs/16_DATABASE_GOVERNANCE.md installed (central reference)
- [ ] Other docs updated:

## Verification

- [x] bash -n bin/rp-issue-create bin/rp-issue-audit bin/rp-issue-work bin/rp-issue-closeout
- [x] git diff --check
- [ ] Typecheck passes
- [ ] Build passes
- [ ] Tests pass
- [ ] Manually verified

## Risks for Jim Review

The reusable workflow points at rp-governance-kit@$KIT_REF. Merge after the governance-kit source PR is merged if main is expected to contain the new source scripts.

## Suggested Review Focus

Confirm the repo should use the standard lightweight governance footprint." )
    echo "Created PR: $pr_url"
    PR_URLS+=("$repo -> $pr_url")
    INSTALLED+=("$repo")
  fi

  cd "$start_dir"
  rm -rf "$tmpdir"
}

summary() {
  echo ""
  echo "========================================"
  echo "Summary"
  echo "========================================"
  printf 'Installed/updated: %s\n' "${#INSTALLED[@]}"
  printf 'Already up to date: %s\n' "${#UPTODATE[@]}"
  printf 'Skipped: %s\n' "${#SKIPPED[@]}"
  printf 'Failed: %s\n' "${#FAILED[@]}"

  if [[ ${#PR_URLS[@]} -gt 0 ]]; then
    echo ""
    echo "PRs:"
    printf '  - %s\n' "${PR_URLS[@]}"
  fi
  if [[ ${#FAILED[@]} -gt 0 ]]; then
    echo ""
    echo "Failures:"
    printf '  - %s\n' "${FAILED[@]}"
    return 1
  fi
}

parse_args "$@"
preflight

for repo in "${REPOS[@]}"; do
  install_one "$repo"
done

summary
