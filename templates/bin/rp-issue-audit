#!/usr/bin/env bash
# rp-issue-audit - check whether an existing GitHub Issue follows Retailpulses governance
set -euo pipefail

ISSUE_NUMBER=""
FIX_DRAFT=false
APPLY=false

REQUIRED_SECTIONS=(
  "Problem / Opportunity"
  "Proposed Solution"
  "Current State"
  "Scope"
  "Out of Scope"
  "User Workflow Impact"
  "Data Model Impact"
  "Supabase Impact"
  "Runtime / Infrastructure Impact"
  "Cloudflare Dependency"
  "Baserow Dependency / Legacy Impact"
  "Documentation Requirement"
  "Acceptance Criteria"
  "Risks / Open Questions"
)

usage() {
  cat <<-USAGE
Usage: bin/rp-issue-audit <issue-number> [options]

Check whether an existing GitHub Issue follows Retailpulses governance.

Options:
  --fix-draft  Generate .tmp/issue-correction-<issue-number>.md
  --apply      Update the Issue with the generated correction draft
  --help       Show this help
USAGE
}

die() {
  echo "Error: $*" >&2
  exit 1
}

preflight() {
  if ! command -v gh &>/dev/null; then
    die "gh CLI is not installed or not in PATH"
  fi

  if ! gh auth status &>/dev/null; then
    die "gh CLI is not authenticated. Run 'gh auth login' first."
  fi
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)
        usage
        exit 0
        ;;
      --fix-draft)
        FIX_DRAFT=true
        shift
        ;;
      --apply)
        APPLY=true
        FIX_DRAFT=true
        shift
        ;;
      -*)
        die "Unknown option: $1"
        ;;
      *)
        if [[ -n "$ISSUE_NUMBER" ]]; then
          die "Only one issue number is allowed"
        fi
        ISSUE_NUMBER="$1"
        shift
        ;;
    esac
  done

  [[ -n "$ISSUE_NUMBER" ]] || {
    usage
    exit 1
  }

  [[ "$ISSUE_NUMBER" =~ ^[0-9]+$ ]] || die "Issue number must be numeric"
}

section_exists_in_file() {
  local file="$1"
  local section="$2"
  grep -Eiq "^#{1,6}[[:space:]]*$section[[:space:]]*$" "$file"
}

section_text() {
  local file="$1"
  local section="$2"
  awk -v section="$section" '
    BEGIN { in_section = 0 }
    {
      if ($0 ~ "^#{1,6}[[:space:]]*" section "[[:space:]]*$") {
        in_section = 1
        next
      }
      if (in_section && $0 ~ "^#{1,6}[[:space:]]+") {
        exit
      }
      if (in_section) {
        print
      }
    }
  ' "$file"
}

section_denies_impact() {
  local file="$1"
  local section="$2"
  local text
  text=$(section_text "$file" "$section" | tr '[:upper:]' '[:lower:]')
  echo "$text" | grep -Eq 'no |none|n/a|not applicable|no impact|no new'
}

body_mentions() {
  local file="$1"
  local pattern="$2"
  grep -Ev '^[[:space:]]*#{1,6}[[:space:]]+' "$file" |
    grep -Eiv '^[[:space:]]*-[[:space:]]*\[[ xX]\][[:space:]]*(no|n/a|not applicable)' |
    grep -Eiq "$pattern"
}

generate_fix_draft() {
  local body_file="$1"
  local draft="$2"
  shift 2
  local missing_sections=("$@")

  cp "$body_file" "$draft"
  {
    echo ""
    echo "---"
    echo ""
    echo "## Governance correction required"
    echo ""
    echo "This correction draft was generated by \`bin/rp-issue-audit $ISSUE_NUMBER --fix-draft\`."
    echo "Replace each TBD with specific Issue context before mergeable coding continues."
  } >> "$draft"

  local section
  for section in "${missing_sections[@]}"; do
    {
      echo ""
      echo "## $section"
      echo ""
      echo "TBD - required governance field. Correct this before coding or PR merge."
    } >> "$draft"
  done

  echo "Correction draft generated: $draft"
}

main() {
  parse_args "$@"
  preflight

  mkdir -p .tmp
  local body_file=".tmp/issue-$ISSUE_NUMBER-body.md"
  local title_file=".tmp/issue-$ISSUE_NUMBER-title.txt"
  local status_file=".tmp/issue-audit-$ISSUE_NUMBER.status"
  local correction_file=".tmp/issue-correction-$ISSUE_NUMBER.md"

  echo "=== Auditing issue #$ISSUE_NUMBER ==="
  gh issue view "$ISSUE_NUMBER" --json title --jq '.title' > "$title_file"
  gh issue view "$ISSUE_NUMBER" --json body --jq '.body // ""' > "$body_file"

  local title
  title=$(cat "$title_file")
  echo "Issue: #$ISSUE_NUMBER - $title"
  echo ""

  local missing=()
  local section
  for section in "${REQUIRED_SECTIONS[@]}"; do
    if ! section_exists_in_file "$body_file" "$section"; then
      missing+=("$section")
    fi
  done

  local warnings=()
  if body_mentions "$body_file" 'cloudflare|worker|wrangler|pages|r2|kv|d1'; then
    if section_exists_in_file "$body_file" "Cloudflare Dependency" && section_denies_impact "$body_file" "Cloudflare Dependency"; then
      warnings+=("Cloudflare-related keywords found, but Cloudflare Dependency appears to say no impact.")
    fi
  fi

  if body_mentions "$body_file" 'supabase|migration|rls|postgres|edge function'; then
    if section_exists_in_file "$body_file" "Supabase Impact" && section_denies_impact "$body_file" "Supabase Impact"; then
      warnings+=("Supabase/data keywords found, but Supabase Impact appears to say no impact.")
    fi
  fi

  if body_mentions "$body_file" 'baserow|legacy|csv import|old flow|backfill'; then
    if section_exists_in_file "$body_file" "Baserow Dependency / Legacy Impact" && section_denies_impact "$body_file" "Baserow Dependency / Legacy Impact"; then
      warnings+=("Baserow/legacy keywords found, but Baserow Dependency / Legacy Impact appears to say no impact.")
    fi
  fi

  if body_mentions "$body_file" 'frontend|ui|page|route|component|screen|form'; then
    if section_exists_in_file "$body_file" "User Workflow Impact" && section_denies_impact "$body_file" "User Workflow Impact"; then
      warnings+=("Frontend/UI keywords found, but User Workflow Impact appears to say no impact.")
    fi
  fi

  if body_mentions "$body_file" 'table|column|schema|model|migration|field'; then
    if section_exists_in_file "$body_file" "Data Model Impact" && section_denies_impact "$body_file" "Data Model Impact"; then
      warnings+=("Data-model keywords found, but Data Model Impact appears to say no impact.")
    fi
  fi

  if [[ ${#missing[@]} -gt 0 ]]; then
    echo "FAIL"
    echo ""
    echo "Missing required governance sections:"
    printf '  - %s\n' "${missing[@]}"
    echo ""
    echo "Suggested correction:"
    echo "  bin/rp-issue-audit $ISSUE_NUMBER --fix-draft"
    echo "  gh issue edit $ISSUE_NUMBER --body-file $correction_file"
    echo ""
    echo "FAIL" > "$status_file"

    if [[ "$FIX_DRAFT" == true ]]; then
      generate_fix_draft "$body_file" "$correction_file" "${missing[@]}"
    fi

    if [[ "$APPLY" == true ]]; then
      echo "Applying correction draft to issue #$ISSUE_NUMBER..."
      gh issue edit "$ISSUE_NUMBER" --body-file "$correction_file"
      echo "Issue updated. Review and replace all TBD fields before coding or PR merge."
    fi

    exit 1
  fi

  if [[ ${#warnings[@]} -gt 0 ]]; then
    echo "WARN"
    echo ""
    echo "Potential impact mismatches:"
    printf '  - %s\n' "${warnings[@]}"
    echo ""
    echo "Suggested correction:"
    echo "  Update the relevant impact section if the keyword is material, or explain why there is no impact."
    echo "WARN" > "$status_file"
    exit 0
  fi

  echo "PASS"
  echo ""
  echo "All required governance sections are present."
  echo "PASS" > "$status_file"
}

main "$@"
