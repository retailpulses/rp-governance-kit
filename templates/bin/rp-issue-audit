#!/usr/bin/env bash
# rp-issue-audit - check whether an existing GitHub Issue follows Retailpulses governance
set -euo pipefail

ISSUE_NUMBER=""
FIX_DRAFT=false
APPLY=false

REQUIRED_SECTIONS=(
  "Problem / Opportunity"
  "Proposed Solution"
  "Current State"
  "Scope"
  "Out of Scope"
  "User Workflow Impact"
  "Data Model Impact"
  "Supabase Impact"
  "Database Governance"
  "Runtime / Infrastructure Impact"
  "Cloudflare Dependency"
  "Baserow Dependency / Legacy Impact"
  "Frontend Stack Impact"
  "Engineering Standards Impact"
  "Frontend Standards Impact"
  "Secrets / Permissions Impact"
  "Platform Dependency Impact"
  "Documentation Requirement"
  "Acceptance Criteria"
  "Risks / Open Questions"
)

usage() {
  cat <<-USAGE
Usage: bin/rp-issue-audit <issue-number> [options]

Check whether an existing GitHub Issue follows Retailpulses governance.

Options:
  --fix-draft  Generate .tmp/issue-correction-<issue-number>.md
  --apply      Update the Issue with the generated correction draft
  --help       Show this help
USAGE
}

die() {
  echo "Error: $*" >&2
  exit 1
}

preflight() {
  if ! command -v gh &>/dev/null; then
    die "gh CLI is not installed or not in PATH"
  fi

  if ! gh auth status &>/dev/null; then
    die "gh CLI is not authenticated. Run 'gh auth login' first."
  fi
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)
        usage
        exit 0
        ;;
      --fix-draft)
        FIX_DRAFT=true
        shift
        ;;
      --apply)
        APPLY=true
        FIX_DRAFT=true
        shift
        ;;
      -*)
        die "Unknown option: $1"
        ;;
      *)
        if [[ -n "$ISSUE_NUMBER" ]]; then
          die "Only one issue number is allowed"
        fi
        ISSUE_NUMBER="$1"
        shift
        ;;
    esac
  done

  [[ -n "$ISSUE_NUMBER" ]] || {
    usage
    exit 1
  }

  [[ "$ISSUE_NUMBER" =~ ^[0-9]+$ ]] || die "Issue number must be numeric"
}

section_exists_in_file() {
  local file="$1"
  local section="$2"
  grep -Eiq "^#{1,6}[[:space:]]*$section[[:space:]]*$" "$file"
}

section_text() {
  local file="$1"
  local section="$2"
  awk -v section="$section" '
    BEGIN { in_section = 0 }
    {
      if ($0 ~ "^#{1,6}[[:space:]]*" section "[[:space:]]*$") {
        in_section = 1
        next
      }
      if (in_section && $0 ~ "^#{1,6}[[:space:]]+") {
        exit
      }
      if (in_section) {
        print
      }
    }
  ' "$file"
}

section_denies_impact() {
  local file="$1"
  local section="$2"
  local text
  text=$(section_text "$file" "$section" | tr '[:upper:]' '[:lower:]')
  echo "$text" | grep -Eq 'no |none|n/a|not applicable|no impact|no new'
}

body_mentions() {
  local file="$1"
  local pattern="$2"
  grep -Ev '^[[:space:]]*#{1,6}[[:space:]]+' "$file" |
    grep -Eiv '^[[:space:]]*-[[:space:]]*\[[ xX]\][[:space:]]*(no|n/a|not applicable)' |
    grep -Eiq "$pattern"
}

generate_fix_draft() {
  local body_file="$1"
  local draft="$2"
  shift 2
  local missing_sections=("$@")

  cp "$body_file" "$draft"
  {
    echo ""
    echo "---"
    echo ""
    echo "## Governance correction required"
    echo ""
    echo "This correction draft was generated by \`bin/rp-issue-audit $ISSUE_NUMBER --fix-draft\`."
    echo "Replace each TBD with specific Issue context before mergeable coding continues."
  } >> "$draft"

  local section
  for section in "${missing_sections[@]}"; do
    {
      echo ""
      echo "## $section"
      echo ""
      echo "TBD - required governance field. Correct this before coding or PR merge."
    } >> "$draft"
  done

  echo "Correction draft generated: $draft"
}

main() {
  parse_args "$@"
  preflight

  mkdir -p .tmp
  local body_file=".tmp/issue-$ISSUE_NUMBER-body.md"
  local title_file=".tmp/issue-$ISSUE_NUMBER-title.txt"
  local status_file=".tmp/issue-audit-$ISSUE_NUMBER.status"
  local correction_file=".tmp/issue-correction-$ISSUE_NUMBER.md"

  echo "=== Auditing issue #$ISSUE_NUMBER ==="
  gh issue view "$ISSUE_NUMBER" --json title --jq '.title' > "$title_file"
  gh issue view "$ISSUE_NUMBER" --json body --jq '.body // ""' > "$body_file"

  local title
  title=$(cat "$title_file")
  echo "Issue: #$ISSUE_NUMBER - $title"
  echo ""

  local missing=()
  local section
  for section in "${REQUIRED_SECTIONS[@]}"; do
    if ! section_exists_in_file "$body_file" "$section"; then
      missing+=("$section")
    fi
  done

  local warnings=()
  # All keyword-based findings below are HEURISTIC — they flag possible
  # mismatches but are NOT factual architecture conclusions. Agents must
  # not convert these warnings into unsupported blocking rules
  # (e.g., "API-only required because schema ownership is absent").
  # Source: templates/bin/rp-issue-audit (central governance-kit)

  if body_mentions "$body_file" 'cloudflare|worker|wrangler|pages|r2|kv|d1'; then
    if section_exists_in_file "$body_file" "Cloudflare Dependency" && section_denies_impact "$body_file" "Cloudflare Dependency"; then
      warnings+=("[heuristic] Cloudflare-related keywords found, but Cloudflare Dependency appears to say no impact. Verify and update if material.")
    fi
  fi

  if body_mentions "$body_file" 'supabase|migration|rls|postgres|edge function'; then
    if section_exists_in_file "$body_file" "Supabase Impact" && section_denies_impact "$body_file" "Supabase Impact"; then
      warnings+=("[heuristic] Supabase/data keywords found, but Supabase Impact appears to say no impact. Verify and update if material.")
    fi
  fi

  if body_mentions "$body_file" 'baserow|legacy|csv import|old flow|backfill'; then
    if section_exists_in_file "$body_file" "Baserow Dependency / Legacy Impact" && section_denies_impact "$body_file" "Baserow Dependency / Legacy Impact"; then
      warnings+=("[heuristic] Baserow/legacy keywords found, but Baserow Dependency / Legacy Impact appears to say no impact. Verify and update if material.")
    fi
  fi

  if body_mentions "$body_file" 'frontend|ui|page|route|component|screen|form'; then
    if section_exists_in_file "$body_file" "User Workflow Impact" && section_denies_impact "$body_file" "User Workflow Impact"; then
      warnings+=("[heuristic] Frontend/UI keywords found, but User Workflow Impact appears to say no impact. Verify and update if material.")
    fi
    if section_exists_in_file "$body_file" "Frontend Stack Impact"; then
      local frontend_text
      frontend_text=$(section_text "$body_file" "Frontend Stack Impact" | tr '[:upper:]' '[:lower:]')
      if ! echo "$frontend_text" | grep -qE 'react.*vite.*typescript|follows.*standard|exception'; then
        warnings+=("[heuristic] Frontend keywords found - Frontend Stack Impact should mention React + Vite + TypeScript compliance or document an exception.")
      fi
    fi
  fi

  if body_mentions "$body_file" 'table|column|schema|model|migration|field'; then
    if section_exists_in_file "$body_file" "Data Model Impact" && section_denies_impact "$body_file" "Data Model Impact"; then
      warnings+=("[heuristic] Data-model keywords found, but Data Model Impact appears to say no impact. Verify and update if material.")
    fi
  fi

  if body_mentions "$body_file" 'migration|schema|table|view|function|rpc|rls|storage|generated.type|access.class|hosted.write|service.role'; then
    if section_exists_in_file "$body_file" "Database Governance"; then
      if section_denies_impact "$body_file" "Database Governance"; then
        warnings+=("[heuristic] Database governance keywords found, but Database Governance appears to say no impact. Verify and update if material.")
      fi
    else
      warnings+=("[heuristic] Database governance keywords found, but Database Governance section is missing.")
    fi
  fi

  # Schema ownership check: warn about schema changes, but do NOT infer
  # runtime access restrictions from schema ownership.
  # Schema ownership and runtime access are separate governance dimensions
  # per DATABASE_GOVERNANCE.md §2b.
  # Source: docs/DATABASE_GOVERNANCE.md §2b
  if body_mentions "$body_file" 'schema|migration|table|view|function|alter table|create table'; then
    if [[ -f "docs/DATABASE_OWNERSHIP.yaml" ]]; then
      warnings+=("[advisory] Database schema changes proposed. Verify domain ownership against docs/DATABASE_OWNERSHIP.yaml. NOTE: Schema ownership does not determine runtime access path (see DATABASE_GOVERNANCE.md §2b).")
    elif [[ -f "docs/16_DATABASE_GOVERNANCE.md" ]]; then
      warnings+=("[advisory] Database schema changes proposed. Check central DATABASE_OWNERSHIP.yaml in rp-governance-kit for domain ownership. NOTE: Schema ownership does not determine runtime access path.")
    fi
  fi

  # Local-vs-central conflict detection: check if installed local rules
  # claim "stricter" or "API-only" without central-policy support
  # Source: templates/bin/rp-issue-audit (central governance-kit)
  if [[ -f "docs/16_DATABASE_GOVERNANCE.local.md" ]]; then
    if grep -qiE 'API.only.*consumer|database.consumer.only|not.direct' "docs/16_DATABASE_GOVERNANCE.local.md" 2>/dev/null; then
      if ! grep -qiE 'workload.*declaration|access.path.*postgrest|access.path.*supavisor|access.path.*direct' "docs/16_DATABASE_GOVERNANCE.local.md" 2>/dev/null; then
        warnings+=("[conflict] docs/16_DATABASE_GOVERNANCE.local.md may imply API-only access based on schema ownership alone. Central policy (DATABASE_GOVERNANCE.md §2b) explicitly separates schema ownership from runtime access path. A local rule that claims API-only solely because the repo lacks schema ownership conflicts with central policy.")
      fi
    fi
  fi

  # Check for the "stricter" ambiguity pattern in AGENTS.md or CLAUDE.md
  for cfg_file in AGENTS.md CLAUDE.md; do
    if [[ -f "$cfg_file" ]]; then
      if grep -qiE 'central.governance.wins.*unless.*stricter|repo.rules.are.stricter' "$cfg_file" 2>/dev/null; then
        warnings+=("[conflict] $cfg_file contains 'central governance wins unless repo rules are stricter' language. This phrasing is ambiguous and may cause agents to incorrectly accept API-only rules that conflict with central policy (DATABASE_GOVERNANCE.md §2b). Update to: 'Central governance wins. A repository-local rule that conflicts with central policy is reported as a conflict, even if the local rule is more restrictive.'")
      fi
    fi
  done

  if [[ ${#missing[@]} -gt 0 ]]; then
    echo "FAIL"
    echo ""
    echo "Missing required governance sections:"
    printf '  - %s\n' "${missing[@]}"
    echo ""
    echo "Suggested correction:"
    echo "  bin/rp-issue-audit $ISSUE_NUMBER --fix-draft"
    echo "  gh issue edit $ISSUE_NUMBER --body-file $correction_file"
    echo ""
    echo "FAIL" > "$status_file"

    if [[ "$FIX_DRAFT" == true ]]; then
      generate_fix_draft "$body_file" "$correction_file" "${missing[@]}"
    fi

    if [[ "$APPLY" == true ]]; then
      echo "Applying correction draft to issue #$ISSUE_NUMBER..."
      gh issue edit "$ISSUE_NUMBER" --body-file "$correction_file"
      echo "Issue updated. Review and replace all TBD fields before coding or PR merge."
    fi

    exit 1
  fi

  if [[ ${#warnings[@]} -gt 0 ]]; then
    echo "WARN"
    echo ""
    echo "Governance findings:"
    printf '  - %s\n' "${warnings[@]}"
    echo ""
    echo "Suggested correction:"
    echo "  Update the relevant impact section if the finding is material."
    echo "  Heuristic findings may be dismissed if keywords are incidental."
    echo "  Conflict findings require resolution before coding."
    echo "WARN" > "$status_file"
    exit 0
  fi

  echo "PASS"
  echo ""
  echo "All required governance sections are present."
  echo "PASS" > "$status_file"
}

main "$@"
