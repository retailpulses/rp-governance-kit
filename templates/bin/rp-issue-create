#!/usr/bin/env bash
# rp-issue-create - generate and optionally submit a governed GitHub Issue
set -euo pipefail

ISSUE_KIND=""
SUBMIT=false
FORCE=false
TITLE=""
DRAFT=".tmp/issue-draft.md"

VALID_KINDS=(feature bug architecture data-model docs workflow)
REQUIRED_SECTIONS=(
  "Problem / Opportunity"
  "Proposed Solution"
  "Current State"
  "Scope"
  "Out of Scope"
  "User Workflow Impact"
  "Data Model Impact"
  "Supabase Impact"
  "Runtime / Infrastructure Impact"
  "Cloudflare Dependency"
  "Baserow Dependency / Legacy Impact"
  "Documentation Requirement"
  "Acceptance Criteria"
  "Risks / Open Questions"
)

usage() {
  cat <<-USAGE
Usage: bin/rp-issue-create <type> [options]

Create a governed Issue draft. Review and edit .tmp/issue-draft.md before submitting.

Types:
  feature, bug, architecture, data-model, docs, workflow

Options:
  --title <title>  Required with --submit. A type prefix is added automatically.
  --submit         Submit the existing generated draft after local validation.
  --force          Allow a low-structure Issue and add a governance warning note.
  --help           Show this help.
USAGE
}

die() {
  echo "Error: $*" >&2
  exit 1
}

has_kind() {
  local wanted="$1"
  local kind
  for kind in "${VALID_KINDS[@]}"; do
    [[ "$kind" == "$wanted" ]] && return 0
  done
  return 1
}

preflight() {
  if ! command -v gh &>/dev/null; then
    die "gh CLI is not installed or not in PATH"
  fi
  if ! gh auth status &>/dev/null; then
    die "gh CLI is not authenticated. Run 'gh auth login' first."
  fi
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)
        usage
        exit 0
        ;;
      --submit)
        SUBMIT=true
        shift
        ;;
      --force)
        FORCE=true
        shift
        ;;
      --title)
        [[ $# -ge 2 ]] || die "--title requires a value"
        TITLE="$2"
        shift 2
        ;;
      -*)
        die "Unknown option: $1"
        ;;
      *)
        if [[ -n "$ISSUE_KIND" ]]; then
          die "Only one issue type is allowed"
        fi
        ISSUE_KIND="$1"
        shift
        ;;
    esac
  done

  [[ -n "$ISSUE_KIND" ]] || {
    usage
    exit 1
  }
  has_kind "$ISSUE_KIND" || die "Unknown type: $ISSUE_KIND. Valid types: ${VALID_KINDS[*]}"
}

title_prefix() {
  case "$ISSUE_KIND" in
    feature) echo "[Feature] " ;;
    bug) echo "[Bug] " ;;
    architecture) echo "[Architecture] " ;;
    data-model) echo "[Data Model] " ;;
    docs) echo "[Docs] " ;;
    workflow) echo "[Workflow] " ;;
  esac
}

label_name() {
  case "$ISSUE_KIND" in
    feature) echo "enhancement" ;;
    bug) echo "bug" ;;
    architecture) echo "architecture" ;;
    data-model) echo "data-model" ;;
    docs) echo "documentation" ;;
    workflow) echo "workflow" ;;
  esac
}

template_hint() {
  case "$ISSUE_KIND" in
    feature) echo "feature_request.yml" ;;
    bug) echo "bug_report.yml" ;;
    architecture) echo "architecture_change.yml" ;;
    data-model) echo "architecture_change.yml" ;;
    docs) echo "agent_task.yml" ;;
    workflow) echo "agent_task.yml" ;;
  esac
}

print_local_templates() {
  local template_dir=".github/ISSUE_TEMPLATE"

  echo "=== Issue template detection ==="
  if [[ -d "$template_dir" ]]; then
    echo "Repo-local templates found in $template_dir:"
    local file name
    while IFS= read -r file; do
      name=$(grep -E '^name:' "$file" 2>/dev/null | head -n 1 | sed 's/^name:[[:space:]]*//; s/^"//; s/"$//' || true)
      [[ -n "$name" ]] || name="$(basename "$file")"
      echo "  - $(basename "$file") ($name)"
    done < <(find "$template_dir" -maxdepth 1 -type f \( -name '*.yml' -o -name '*.yaml' -o -name '*.md' \) | sort)
  else
    echo "No repo-local .github/ISSUE_TEMPLATE/ directory found."
    echo "GitHub may still offer organization fallback templates from retailpulses/.github in the web UI."
  fi
  echo ""
}

write_draft() {
  mkdir -p "$(dirname "$DRAFT")"

  cat > "$DRAFT" <<-'ISSUE_BODY'
<!-- rp-governance-format: v1 -->
<!-- Generated by bin/rp-issue-create. Do not replace this with raw gh issue create --body for normal development work. -->

## Problem / Opportunity

<!-- What problem are we solving, or what opportunity are we capturing? -->

## Proposed Solution

<!-- Describe the intended solution, behavior, inputs, outputs, and user-visible result. -->

## Current State

<!-- What happens today? Include links to relevant code, docs, workflows, or existing Issues. -->

## Scope

- [ ] TBD

## Out of Scope

- [ ] TBD

## User Workflow Impact

- [ ] No user workflow impact
- [ ] Changes user workflow - describe:

## Data Model Impact

- [ ] No data model changes
- [ ] Existing tables/fields reused - list:
- [ ] New tables/fields/migrations needed - justify:

## Supabase Impact

- [ ] No Supabase impact
- [ ] Supabase migrations/functions/policies/storage affected - describe:

## Runtime / Infrastructure Impact

- [ ] No runtime or infrastructure impact
- [ ] GitHub Actions affected
- [ ] Cloudflare Worker/Pages affected
- [ ] VPS service affected
- [ ] Static/frontend runtime affected
- [ ] Other - describe:

## Cloudflare Dependency

- [ ] No new Cloudflare dependency
- [ ] Existing Cloudflare dependency changed - describe:
- [ ] New Cloudflare dependency requested - justify and isolate behind an adapter:

## Baserow Dependency / Legacy Impact

- [ ] No Baserow or legacy-system impact
- [ ] Existing Baserow dependency affected - describe:
- [ ] Legacy behavior/data compatibility affected - describe:

## Documentation Requirement

- [ ] No docs changes needed
- [ ] docs/00_CURRENT_STATE.md update required
- [ ] docs/05_DECISION_LOG.md entry required
- [ ] Other docs impacted - list:

## Acceptance Criteria

- [ ] TBD
- [ ] TBD
- [ ] TBD

## Risks / Open Questions

- TBD
ISSUE_BODY

  if [[ "$FORCE" == true ]]; then
    append_force_warning
  fi
}

append_force_warning() {
  if ! grep -q "Governance exception warning" "$DRAFT" 2>/dev/null; then
    cat >> "$DRAFT" <<-'ISSUE_BODY'

## Governance exception warning

Issue created with `bin/rp-issue-create --force`. This may intentionally be minimal, but missing governance fields must be corrected before mergeable coding proceeds or before PR merge for emergency hotfixes.
ISSUE_BODY
  fi
}

section_exists() {
  local section="$1"
  grep -Eiq "^#{1,6}[[:space:]]*$section[[:space:]]*$" "$DRAFT"
}

validate_draft() {
  [[ -f "$DRAFT" ]] || die "Draft not found: $DRAFT. Run bin/rp-issue-create $ISSUE_KIND first."

  local missing=()
  local section
  for section in "${REQUIRED_SECTIONS[@]}"; do
    if ! section_exists "$section"; then
      missing+=("$section")
    fi
  done

  if [[ ${#missing[@]} -gt 0 ]]; then
    echo "FAIL: Issue draft missing required governance sections:"
    printf '  - %s\n' "${missing[@]}"
    return 1
  fi

  if [[ "$FORCE" == true ]]; then
    append_force_warning
    echo "WARN: --force used. Governance exception warning added to $DRAFT."
    return 0
  fi

  if grep -q "<!--" "$DRAFT"; then
    echo "FAIL: Issue draft still contains placeholder comments. Edit $DRAFT before submitting, or use --force for an explicit exception."
    return 1
  fi

  if grep -q "TBD" "$DRAFT"; then
    echo "FAIL: Issue draft still contains TBD placeholders. Complete them before submitting, or use --force for an explicit exception."
    return 1
  fi

  local meaningful_lines
  meaningful_lines=$(grep -Ev '^[[:space:]]*$|^[[:space:]]*#{1,6}[[:space:]]|^[[:space:]]*-[[:space:]]*\[[ xX]\][[:space:]]*$|^[[:space:]]*-[[:space:]]*$|^[[:space:]]*<!--' "$DRAFT" | wc -l | tr -d ' ')
  if [[ "$meaningful_lines" -lt 8 ]]; then
    echo "FAIL: Issue draft is too low-structure for normal development work. Complete the fields or use --force for an explicit exception."
    return 1
  fi

  echo "PASS: Issue draft passed local governance validation."
  return 0
}

label_exists() {
  local label="$1"
  gh label list --limit 200 --json name --jq '.[].name' 2>/dev/null | grep -Fxq "$label"
}

print_suggested_command() {
  local prefix label template
  prefix=$(title_prefix)
  label=$(label_name)
  template=$(template_hint)

  echo "Generated governed Issue draft: $DRAFT"
  echo ""
  echo "Do not use raw 'gh issue create --body' for normal development work."
  echo "Use this generated body file, a GitHub UI Issue Form/template, or an explicit user-approved exception."
  echo ""
  echo "Suggested CLI command after editing:"
  echo ""
  echo "  gh issue create --title \"${prefix}<your title>\" --body-file \"$DRAFT\" --label \"$label\""
  echo ""
  echo "Suggested GitHub UI template type:"
  echo ""
  echo "  $template"
  echo ""
  echo "To submit through the governed entrypoint after editing:"
  echo ""
  echo "  bin/rp-issue-create $ISSUE_KIND --title \"<your title>\" --submit"
  echo ""
}

submit_issue() {
  [[ -n "$TITLE" ]] || die "--submit requires --title"
  validate_draft

  local prefix label
  prefix=$(title_prefix)
  label=$(label_name)

  echo "=== Submitting governed issue... ==="
  if label_exists "$label"; then
    gh issue create --title "$prefix$TITLE" --body-file "$DRAFT" --label "$label"
  else
    echo "Label '$label' not found in this repo; submitting without label."
    gh issue create --title "$prefix$TITLE" --body-file "$DRAFT"
  fi
}

parse_args "$@"
preflight
print_local_templates

if [[ "$SUBMIT" == true ]]; then
  [[ -f "$DRAFT" ]] || write_draft
  submit_issue
else
  write_draft
  print_suggested_command
fi
